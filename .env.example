# Copy to .env and adjust as needed. Every value is optional - the tool runs
# with sensible defaults and degrades gracefully when services are absent.

# --- Fetching -------------------------------------------------------------
# RADAR_HTTP_TIMEOUT=20
# RADAR_MAX_ITEMS_PER_SOURCE=25
# RADAR_LOOKBACK_DAYS=14

# NCBI asks E-utilities callers to identify themselves (improves rate limits).
# ENTREZ_EMAIL=you@example.com

# --- Optional LLM summariser ---------------------------------------------
# Leave RADAR_LLM_PROVIDER unset (or "none") for deterministic extractive
# summaries. Set to "google" and provide a key to enable LLM summaries.
# RADAR_LLM_PROVIDER=google
# GOOGLE_API_KEY=your_key_here
# GOOGLE_MODEL=gemini-2.5-flash
# RADAR_LLM_MAX_TOKENS=512
# Decoding temperature. 0 = deterministic/grounded (recommended, anti-hallucination).
# RADAR_LLM_TEMPERATURE=0.0

# --- Email delivery (for `run --email`) -----------------------------------
# Leave unset to skip emailing. For Gmail, EMAIL_PASSWORD must be an App
# Password (Google Account -> Security -> App passwords), NOT your login
# password, and 2-Step Verification must be on.
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USERNAME=you@gmail.com
# EMAIL_PASSWORD=your_16_char_app_password
# EMAIL_TO=you@gmail.com          # defaults to EMAIL_USERNAME
# RADAR_SEEN_PRUNE_DAYS=30        # forget "seen" stories older than this
